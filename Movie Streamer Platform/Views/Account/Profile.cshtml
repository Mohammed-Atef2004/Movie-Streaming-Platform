@using DAL.Models
@model ApplicationUser

@{
    ViewData["Title"] = "My Profile";

    var imageUrl = string.IsNullOrEmpty(Model.ImageURL)
        ? "/Images/default-user.png"
        : $"/Images/{Model.ImageURL}";

    // var totalWatched = Model.WatchedMovies.Count + Model.WatchedSeries.Count;
    // var totalFavorites = Model.FavouriteMovies.Count + Model.FavouriteSeries.Count;
}

<style>

    body {
        background-color: #0b0b0b;
        color: white;
    }

    .profile-hero {
        position: relative;
        height: 350px;
        background: linear-gradient( rgba(0,0,0,.45), rgba(0,0,0,.95)), url('/images/profile-cover.jpg');
        background-size: cover;
        background-position: center;
    }

    .profile-content {
        margin-top: -120px;
        position: relative;
        z-index: 10;
    }

    .profile-card {
        background: rgba(255,255,255,.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 24px;
        padding: 2rem;
        transition: .3s;
        box-shadow: 0 15px 40px rgba(0,0,0,.35);
    }

        .profile-card:hover {
            transform: translateY(-5px);
        }

    .avatar {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid #e50914;
        box-shadow: 0 0 35px rgba(229,9,20,.35);
    }

    .username {
        font-size: 2.2rem;
        font-weight: 700;
    }

    .email {
        color: #b3b3b3;
        font-size: 1rem;
    }

    .badge-custom {
        background: rgba(229,9,20,.15);
        color: #ff4d57;
        border: 1px solid rgba(229,9,20,.4);
        padding: .5rem 1rem;
        border-radius: 50px;
    }

    .stat-card {
        background: #161616;
        border-radius: 18px;
        padding: 1.5rem;
        text-align: center;
        transition: .3s;
        height: 100%;
        border: 1px solid rgba(255,255,255,.05);
    }

        .stat-card:hover {
            transform: translateY(-5px);
            background: #1d1d1d;
        }

    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        color: #e50914;
    }

    .stat-title {
        color: #b3b3b3;
        margin-top: .4rem;
    }

    .info-card {
        background: #161616;
        border-radius: 18px;
        padding: 1.5rem;
        height: 100%;
        border: 1px solid rgba(255,255,255,.05);
        transition: .3s;
    }

        .info-card:hover {
            transform: translateY(-5px);
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .9rem 0;
        border-bottom: 1px solid rgba(255,255,255,.08);
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .btn-netflix {
        background: #e50914;
        border: none;
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-netflix:hover {
            background: #ff1d28;
            color: white;
            transform: scale(1.03);
        }

    .section-title {
        font-weight: 600;
        margin-bottom: 1.5rem;
    }

</style>

<div class="profile-hero"></div>

<div class="container profile-content">

    <!-- Profile Header -->

    <div class="profile-card">

        <div class="row align-items-center g-4">

            <div class="col-lg-3 text-center">

                <img src="@imageUrl"
                     class="avatar"
                     alt="@Model.UserName" />

            </div>

            <div class="col-lg-9">

                <h1 class="username mb-2">
                    @Model.UserName
                </h1>

                <p class="email mb-3">
                    @Model.Email
                </p>

                <div class="d-flex flex-wrap gap-2 mb-4">

                    <span class="badge-custom">
                        Movie Enthusiast
                    </span>

                  @*   <span class="badge-custom">
                        @totalFavorites Favorites
                    </span>

                    <span class="badge-custom">
                        @totalWatched Watched
                    </span> *@

                </div>

                <a asp-action="EditProfile"
                   class="btn btn-netflix">
                    Edit Profile
                </a>

            </div>

        </div>

    </div>

    <!-- Stats -->

    <div class="row mt-4 g-4">

        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    @* @Model.WatchedMovies.Count *@
                </div>
                <div class="stat-title">
                    Movies Watched
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    @* @Model.WatchedSeries.Count *@
                </div>
                <div class="stat-title">
                    Series Watched
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    @* @Model.FavouriteMovies.Count *@
                </div>
                <div class="stat-title">
                    Favorite Movies
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    @* @Model.FavouriteSeries.Count *@
                </div>
                <div class="stat-title">
                    Favorite Series
                </div>
            </div>
        </div>

    </div>

    <!-- Information Section -->

    <div class="row mt-4 g-4">

        <div class="col-lg-6">

            <div class="info-card">

                <h4 class="section-title">
                    Account Information
                </h4>

                <div class="info-row">
                    <span>User Name</span>
                    <span>@Model.UserName</span>
                </div>

                <div class="info-row">
                    <span>Email</span>
                    <span>@Model.Email</span>
                </div>

                <div class="info-row">
                    <span>Phone Number</span>
                    <span>
                        @(string.IsNullOrEmpty(Model.PhoneNumber)
                                                ? "Not Added"
                                                : Model.PhoneNumber)
                    </span>
                </div>

            </div>

        </div>

        <div class="col-lg-6">

            <div class="info-card">

                <h4 class="section-title">
                    Activity Summary
                </h4>

                <div class="info-row">
                    <span>Total Watched</span>
                    @* <span>@totalWatched</span> *@
                </div>

                <div class="info-row">
                    <span>Total Favorites</span>
                    @* <span>@totalFavorites</span> *@
                </div>

                <div class="info-row">
                    <span>Membership</span>
                    <span class="text-danger fw-bold">
                        Premium
                    </span>
                </div>

            </div>

        </div>

    </div>

</div>