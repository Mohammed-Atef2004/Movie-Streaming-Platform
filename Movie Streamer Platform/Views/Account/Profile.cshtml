@using DAL.Models
@model ApplicationUser

@{
    ViewData["Title"] = "My Profile";
}

<style>

    body {
        background: #0b0b0b;
        color: white;
    }

    .profile-hero {
        position: relative;
        height: 320px;
        background: linear-gradient(
                rgba(0,0,0,.6),
                rgba(0,0,0,.95)),
            url('/images/profile-cover.jpg');
        background-size: cover;
        background-position: center;
    }

    .profile-content {
        margin-top: -100px;
        position: relative;
        z-index: 10;
    }

    .profile-card {
        background: rgba(255,255,255,.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,.4);
    }

    .avatar {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid #e50914;
        box-shadow: 0 0 30px rgba(229,9,20,.4);
    }

    .username {
        font-size: 2rem;
        font-weight: 700;
    }

    .email {
        color: #aaa;
    }

    .stat-card {
        background: #161616;
        border-radius: 16px;
        padding: 1.5rem;
        text-align: center;
        transition: .3s;
    }

    .stat-card:hover {
        transform: translateY(-5px);
    }

    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        color: #e50914;
    }

    .info-card {
        background: #161616;
        border-radius: 16px;
        padding: 1.5rem;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid rgba(255,255,255,.08);
        padding: .8rem 0;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .btn-netflix {
        background: #e50914;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 24px;
        font-weight: 600;
        transition: .3s;
    }

    .btn-netflix:hover {
        background: #ff1d28;
        color: white;
        transform: scale(1.03);
    }

</style>

<div class="profile-hero"></div>

<div class="container profile-content">

    <div class="profile-card p-4">

        <div class="row align-items-center">

            <div class="col-md-3 text-center">
                <img src="/Images/@Model.ImageURL"
                     class="avatar"
                     alt="@Model.UserName">
            </div>

            <div class="col-md-6">

                <h2 class="username">
                    @Model.UserName
                </h2>

                <p class="email">
                    @Model.Email
                </p>

                <div class="mt-3">
                    <a asp-action="EditProfile"
                       class="btn btn-netflix">
                        Edit Profile
                    </a>
                </div>

            </div>

        </div>

    </div>

    @* <div class="row mt-4 g-4">

        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    @Model.WatchedMoviesCount
                </div>
                <div>
                    Movies Watched
                </div>
            </div>
        </div> *@

        @* <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    @Model.WatchlistCount
                </div>
                <div>
                    Watchlist
                </div>
            </div>
        </div> *@

        @* <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    @Model.FavoritesCount
                </div>
                <div>
                    Favorites
                </div>
            </div>
        </div> *@

        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-value">
                    Premium
                </div>
                <div>
                    Plan
                </div>
            </div>
        </div>

    </div>

    <div class="info-card mt-4">

        <h4 class="mb-4">
            Account Information
        </h4>

        <div class="info-row">
            <span>User Name</span>
            <span>@Model.UserName</span>
        </div>

        <div class="info-row">
            <span>Email</span>
            <span>@Model.Email</span>
        </div>

      @*   <div class="info-row">
            <span>Joined</span>
            <span>@Model.CreatedAt.ToString("dd MMM yyyy")</span>
        </div> *@

    </div>

</div>
