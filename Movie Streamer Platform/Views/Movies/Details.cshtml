@using BLL.ViewModels
@model MovieVM

@{
    ViewBag.PageTitle = $"{Model?.Title} - Details";

    var posterUrl = string.IsNullOrEmpty(Model?.ImageUrl)
        ? "/images/poster-placeholder.jpg"
        : $"/images/{Model.ImageUrl}";
}

<!-- Hidden SVG Gradient Defs -->
<svg style="position:absolute;width:0;height:0;overflow:hidden" aria-hidden="true">
    <defs>
        <linearGradient id="heartGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#ff6b9d" />
            <stop offset="50%" stop-color="#ff4477" />
            <stop offset="100%" stop-color="#cc0033" />
        </linearGradient>
        <linearGradient id="clockGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#ffe066" />
            <stop offset="50%" stop-color="#ffc107" />
            <stop offset="100%" stop-color="#e6a800" />
        </linearGradient>
    </defs>
</svg>

<style>

    /* =========================
               HERO SECTION
            ========================= */

    .cinema-hero {
        position: relative;
        min-height: 85vh;
        display: flex;
        align-items: center;
        padding: 5rem 0;
        color: white;
        background: url('@posterUrl') center center/cover no-repeat;
        overflow: hidden;
    }

    .cinema-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to right, rgba(0,0,0,.35) 10%, rgba(0,0,0,.15) 55%, rgba(0,0,0,.08) 100% ), linear-gradient( to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.08) 40%, transparent 100% );
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(3px);
        z-index: 1;
    }

    .cinema-content {
        position: relative;
        z-index: 2;
    }

    /* =========================
               POSTER
            ========================= */

    .cinema-poster {
        display: flex;
        justify-content: center;
    }

        .cinema-poster img {
            width: 100%;
            max-width: 300px;
            border-radius: 22px;
            border: 1px solid rgba(255,255,255,.12);
            box-shadow: 0 30px 80px rgba(0,0,0,.75);
            transition: all .35s ease;
        }

            .cinema-poster img:hover {
                transform: scale(1.04) translateY(-6px);
                box-shadow: 0 40px 100px rgba(0,0,0,.85);
            }

    /* =========================
               MOVIE CARD
            ========================= */

    .movie-info-card {
        position: relative;
        overflow: hidden;
        background: rgba(0,0,0,.72);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 25px;
        padding: 2.2rem;
        box-shadow: 0 20px 60px rgba(0,0,0,.65), 0 0 30px rgba(255,193,7,.08);
        transition: transform .35s ease, box-shadow .35s ease, background .35s ease, border-color .35s ease;
    }

        .movie-info-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: -120%;
            width: 80px;
            height: 100%;
            background: linear-gradient( 90deg, transparent, rgba(255,255,255,.12), transparent );
            transform: skewX(-20deg);
            transition: .8s;
        }

        .movie-info-card:hover {
            transform: translateY(-8px) scale(1.01);
            background: rgba(0,0,0,.82);
            border-color: rgba(255,193,7,.35);
            box-shadow: 0 30px 80px rgba(0,0,0,.8), 0 0 40px rgba(255,193,7,.18);
        }

            .movie-info-card:hover::before {
                left: 130%;
            }

    /* =========================
               TITLES
            ========================= */

    .movie-main-title {
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1.1;
        color: white;
        text-shadow: 0 0 12px rgba(255,255,255,.12), 0 6px 25px rgba(0,0,0,.9);
        margin-bottom: 1rem;
    }

    .movie-meta-info {
        font-size: 1rem;
        margin-bottom: 1.8rem;
    }

    .movie-synopsis-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #ffc107;
        text-shadow: 0 0 12px rgba(255,193,7,.25);
    }

    .movie-synopsis-text {
        font-size: 1.08rem;
        line-height: 1.9;
        color: rgba(255,255,255,.97);
        text-shadow: 0 2px 10px rgba(0,0,0,.8);
    }

    /* =========================
               STATS
            ========================= */

    .movie-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 2rem;
    }

    .stat-box {
        flex: 1;
        min-width: 120px;
        background: rgba(0,0,0,.6);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 15px;
        padding: 15px;
        text-align: center;
        transition: all .3s ease;
    }

        .stat-box:hover {
            transform: translateY(-4px);
            background: rgba(0,0,0,.8);
            border-color: rgba(255,193,7,.3);
            box-shadow: 0 10px 25px rgba(0,0,0,.5);
        }

    .stat-label {
        font-size: .9rem;
        font-weight: 600;
        color: rgba(255,255,255,.75);
    }

    .stat-value {
        font-size: 1.3rem;
        font-weight: 800;
        color: #ffc107;
        margin-top: 6px;
        text-shadow: 0 0 12px rgba(255,193,7,.25);
    }

    /* =========================
               BUTTONS
            ========================= */

    .btn-action-watch {
        background: linear-gradient( 135deg, #ff6b6b, #ff8e8e );
        color: white;
        font-weight: 700;
        padding: 14px 35px;
        border-radius: 999px;
        border: none;
        transition: .3s;
    }

        .btn-action-watch:hover {
            transform: translateY(-3px);
            color: white;
        }

    .btn-action-outline {
        background: rgba(255,255,255,.08);
        color: white;
        border: 1px solid rgba(255,255,255,.15);
        backdrop-filter: blur(10px);
        padding: 14px 30px;
        border-radius: 999px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-action-outline:hover {
            background: rgba(255,255,255,.15);
            transform: translateY(-3px);
            color: white;
        }

    /* =========================
               ICON CIRCLE BUTTONS
            ========================= */

    .btn-icon-circle {
        width: 56px;
        height: 56px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,.15);
        background: rgba(255,255,255,.08);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: rgba(255,255,255,.6);
        font-size: 1.35rem;
        padding: 0;
        transition: all .35s cubic-bezier(.4,0,.2,1);
        cursor: pointer;
        position: relative;
        overflow: visible;
    }

        .btn-icon-circle::after {
            content: "";
            position: absolute;
            inset: -1px;
            border-radius: 50%;
            opacity: 0;
            transition: opacity .35s;
            z-index: -1;
        }

        .btn-icon-circle:hover {
            transform: translateY(-4px) scale(1.08);
            border-color: rgba(255,255,255,.3);
            box-shadow: 0 12px 30px rgba(0,0,0,.4);
        }

    /* --- Icon Wrap --- */
    .icon-wrap {
        position: relative;
        width: 26px;
        height: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .icon-wrap svg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            transition: all .4s cubic-bezier(.34,1.56,.64,1);
        }

        .icon-wrap .icon-full {
            opacity: 0;
            transform: scale(0) rotate(-20deg);
        }

        .icon-wrap .icon-empty {
            opacity: 1;
            transform: scale(1) rotate(0deg);
        }

    /* --- Heart States --- */
    .btn-icon-circle.is-active-heart {
        border-color: rgba(255,68,119,.45);
        background: rgba(255,68,119,.12);
        color: #ff4477;
        box-shadow: 0 0 28px rgba(255,68,119,.2), inset 0 0 20px rgba(255,68,119,.06);
    }

        .btn-icon-circle.is-active-heart::after {
            opacity: 1;
            background: radial-gradient( circle, rgba(255,68,119,.15), transparent 70% );
        }

        .btn-icon-circle.is-active-heart:hover {
            border-color: rgba(255,68,119,.65);
            background: rgba(255,68,119,.2);
            box-shadow: 0 0 40px rgba(255,68,119,.3), 0 12px 30px rgba(0,0,0,.4);
            transform: translateY(-4px) scale(1.12);
        }

        .btn-icon-circle.is-active-heart .icon-empty {
            opacity: 0;
            transform: scale(0) rotate(20deg);
        }

        .btn-icon-circle.is-active-heart .icon-full {
            opacity: 1;
            transform: scale(1) rotate(0deg);
            animation: heartBounce .5s cubic-bezier(.34,1.56,.64,1);
        }

    /* --- Clock States --- */
    .btn-icon-circle.is-active-clock {
        border-color: rgba(255,193,7,.4);
        background: rgba(255,193,7,.1);
        color: #ffc107;
        box-shadow: 0 0 28px rgba(255,193,7,.15), inset 0 0 20px rgba(255,193,7,.05);
    }

        .btn-icon-circle.is-active-clock::after {
            opacity: 1;
            background: radial-gradient( circle, rgba(255,193,7,.12), transparent 70% );
        }

        .btn-icon-circle.is-active-clock:hover {
            border-color: rgba(255,193,7,.6);
            background: rgba(255,193,7,.18);
            box-shadow: 0 0 40px rgba(255,193,7,.25), 0 12px 30px rgba(0,0,0,.4);
            transform: translateY(-4px) scale(1.12);
        }

        .btn-icon-circle.is-active-clock .icon-empty {
            opacity: 0;
            transform: scale(0) rotate(20deg);
        }

        .btn-icon-circle.is-active-clock .icon-full {
            opacity: 1;
            transform: scale(1) rotate(0deg);
            animation: clockTick .45s cubic-bezier(.34,1.56,.64,1);
        }

    /* --- Animations --- */
    @@keyframes heartBounce {
        0%

    {
        transform: scale(0) rotate(-20deg);
    }

    40% {
        transform: scale(1.3) rotate(5deg);
    }

    60% {
        transform: scale(0.9) rotate(-3deg);
    }

    80% {
        transform: scale(1.1) rotate(1deg);
    }

    100% {
        transform: scale(1) rotate(0deg);
    }

    }

    @@keyframes clockTick {
        0%

    {
        transform: scale(0) rotate(-20deg);
    }

    35% {
        transform: scale(1.25) rotate(10deg);
    }

    65% {
        transform: scale(0.92) rotate(-5deg);
    }

    100% {
        transform: scale(1) rotate(0deg);
    }

    }

    /* --- Tooltip --- */
    .btn-icon-circle .icon-tooltip {
        position: absolute;
        bottom: calc(100% + 12px);
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background: rgba(0,0,0,.9);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        color: white;
        font-size: .76rem;
        font-weight: 600;
        letter-spacing: .02em;
        padding: 7px 16px;
        border-radius: 12px;
        white-space: nowrap;
        pointer-events: none;
        opacity: 0;
        transition: all .3s cubic-bezier(.4,0,.2,1);
        border: 1px solid rgba(255,255,255,.1);
        box-shadow: 0 8px 24px rgba(0,0,0,.4);
    }

        .btn-icon-circle .icon-tooltip::after {
            content: "";
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 5px solid transparent;
            border-top-color: rgba(0,0,0,.9);
        }

    .btn-icon-circle:hover .icon-tooltip {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }

    /* =========================
               TRAILER
            ========================= */

    #trailer-section {
        background: #090909;
        padding: 6rem 0;
    }

    .video-player-container {
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 60px rgba(0,0,0,.5);
    }

    /* =========================
               TOAST
            ========================= */

    .cinema-toast {
        position: fixed;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: rgba(0,0,0,.88);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        color: white;
        padding: 14px 28px;
        border-radius: 16px;
        font-size: .95rem;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,.12);
        box-shadow: 0 15px 40px rgba(0,0,0,.5);
        opacity: 0;
        pointer-events: none;
        transition: all .4s cubic-bezier(.4,0,.2,1);
        z-index: 9999;
    }

        .cinema-toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

    /* =========================
               MOBILE
            ========================= */

    @@media(max-width:768px) {

        .movie-main-title {
            font-size: 2.2rem;
        }

        .movie-info-card {
            padding: 1.5rem;
        }

        .btn-icon-circle {
            width: 50px;
            height: 50px;
        }

        .icon-wrap {
            width: 22px;
            height: 22px;
        }
    }
</style>

<section class="cinema-hero">

    <div class="cinema-overlay"></div>

    <div class="container cinema-content">

        <div class="row align-items-center g-5">

            <div class="col-lg-4 text-center">

                <div class="cinema-poster">
                    <img src="@posterUrl"
                         alt="@Model?.Title"
                         class="img-fluid"
                         onerror="this.onerror=null;this.src='/images/poster-placeholder.jpg';" />
                </div>

            </div>

            <div class="col-lg-8">

                <div class="movie-info-card">

                    <h1 class="movie-main-title">
                        @Model?.Title
                    </h1>

                    <div class="movie-meta-info d-flex flex-wrap align-items-center gap-3">

                        <span class="badge bg-warning text-dark px-3 py-2 fs-6 fw-bold">
                            @(Model?.Category?.Name ?? "Unknown")
                        </span>

                        <span class="badge bg-dark border px-3 py-2">
                            📅 @Model.Year
                        </span>

                        <span class="badge @(Model.IsFree == true ? "bg-success" : "bg-danger") px-3 py-2">
                            @(Model.IsFree == true ? "FREE" : "PREMIUM")
                        </span>

                    </div>

                    <div class="movie-overview-block">

                        <h4 class="movie-synopsis-title mb-3">
                            Overview
                        </h4>

                        <p class="movie-synopsis-text">
                            @(Model?.Description ?? "No description available.")
                        </p>

                    </div>

                    <div class="movie-stats">

                        <div class="stat-box">
                            <div class="stat-label">Release Year</div>
                            <div class="stat-value">@Model.Year</div>
                        </div>

                        <div class="stat-box">
                            <div class="stat-label">Rating</div>
                            <div class="stat-value">
                                ⭐ @Model.Rating / 10
                            </div>
                        </div>

                        <div class="stat-box">
                            <div class="stat-label">Views</div>
                            <div class="stat-value">
                                @Model.Views
                            </div>
                        </div>

                        <div class="stat-box">
                            <div class="stat-label">Downloads</div>
                            <div class="stat-value">
                                @Model.Downloads
                            </div>
                        </div>

                        <div class="stat-box">
                            <div class="stat-label">Access</div>
                            <div class="stat-value">
                                @(Model.IsFree == true ? "Free" : "Premium")
                            </div>
                        </div>

                    </div>

                    <div class="d-flex flex-wrap align-items-center gap-3 mt-4">

                        @if (!string.IsNullOrWhiteSpace(Model.MovieUrl))
                        {
                            <a href="@Model.MovieUrl"
                               target="_blank"
                               class="btn btn-action-watch">
                                <i class="fas fa-film me-2"></i>
                                Watch Movie
                            </a>
                        }

                        <a href="#trailer-section"
                           class="btn btn-action-outline">
                            <i class="fas fa-play me-2"></i>
                            Watch Trailer
                        </a>

                        @if (User.Identity.IsAuthenticated)
                        {
                            var isFav = ViewBag.IsFavorite == true;
                            var isWatch = ViewBag.IsInWatchList == true;
                            var movieId = Model?.Id ?? 0;

                            <button type="button"
                                    class="btn-icon-circle @(isFav ? "is-active-heart" : "")"
                                    data-movie-id="@movieId"
                                    data-type="fav"
                                    onclick="toggleBtn(this)">
                                <span class="icon-tooltip">@(isFav ? "Remove Favorite" : "Add Favorite")</span>
                                <span class="icon-wrap">
                                    <svg class="icon-empty" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                    </svg>
                                    <svg class="icon-full" viewBox="0 0 24 24">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="url(#heartGrad)" />
                                        <path d="M17.5 2.5c1.2.3 2.3.9 3.2 1.8a5.47 5.47 0 0 1 .7 6.2" fill="none" stroke="rgba(255,255,255,.35)" stroke-width="1.2" stroke-linecap="round" />
                                    </svg>
                                </span>
                            </button>

                            <button type="button"
                                    class="btn-icon-circle @(isWatch ? "is-active-clock" : "")"
                                    data-movie-id="@movieId"
                                    data-type="watch"
                                    onclick="toggleBtn(this)">
                                <span class="icon-tooltip">@(isWatch ? "Remove from Watchlist" : "Watch Later")</span>
                                <span class="icon-wrap">
                                    <svg class="icon-empty" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10" />
                                        <polyline points="12 6 12 12 16 14" />
                                    </svg>
                                    <svg class="icon-full" viewBox="0 0 24 24">
                                        <circle cx="12" cy="12" r="10" fill="url(#clockGrad)" />
                                        <polyline points="12 6 12 12 16 14" fill="none" stroke="rgba(0,0,0,.65)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                                        <circle cx="12" cy="12" r="1.5" fill="rgba(0,0,0,.65)" />
                                    </svg>
                                </span>
                            </button>
                        }

                    </div>
                </div>

            </div>

        </div>

    </div>

</section>

<section id="trailer-section">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-10">

                <h3 class="text-white mb-4">
                    <i class="fas fa-video me-2 text-warning"></i>
                    Official Trailer
                </h3>

                <div class="ratio ratio-16x9 video-player-container">

                    <iframe src="@Model?.TrailerURL"
                            title="Trailer"
                            frameborder="0"
                            allowfullscreen>
                    </iframe>

                </div>

            </div>

        </div>

    </div>

</section>
<section class="py-5 bg-dark">
    <div class="container">

        <h3 class="text-white mb-4">
            Reviews
        </h3>

        @if (User.Identity.IsAuthenticated)
        {
            <div class="card bg-black border-secondary mb-4">
                <div class="card-body">

                    <textarea id="reviewComment"
                          class="form-control mb-3"
                          rows="3"
                          placeholder="Write your review..."></textarea>

                    <button class="btn btn-warning"
                            onclick="addReview(@Model.Id)">
                        Submit Review
                    </button>

                </div>
            </div>
        }

        <div id="reviewsContainer">

            @foreach (var review in ViewBag.Reviews)
            {
                <div class="card bg-black border-secondary mb-3 review-item">
                    <div class="card-body">
                        <h6 class="text-warning">
                            @(review.User?.UserName ?? "Unknown User")
                        </h6>

                        <p class="text-light mb-0">
                            @review.Comment
                        </p>
                    </div>
                </div>
            }

        </div>

    </div>
</section>
<div class="cinema-toast" id="cinema-toast"></div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    (function () {
        'use strict';

        var GUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
        var NUM_RE  = /^\d+$/;

        function validId(id) {
            var s = String(id);
            return GUID_RE.test(s) || NUM_RE.test(s);
        }

            window.toast = function(msg)
    {
        var el = document.getElementById('cinema-toast');
        if (!el) return;

        el.textContent = msg;
        el.classList.add('show');

        clearTimeout(el._t);

        el._t = setTimeout(function () {
            el.classList.remove('show');
        }, 2400);
    }

        function localKey(type, id) { return 'cinema_' + type + '_' + id; }
        function localGet(type, id)  { try { return localStorage.getItem(localKey(type, id)) === '1'; } catch (e) { return false; } }
        function localSet(type, id, v) { try { localStorage.setItem(localKey(type, id), v ? '1' : '0'); } catch (e) {} }

        function ajax(action, id, done) {
            var x = new XMLHttpRequest();
            x.open('POST', '/Movies/' + action, true);
            x.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
            x.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
            x.onreadystatechange = function () {
                if (x.readyState === 4) done(x.status === 200);
            };
            x.send('movieId=' + encodeURIComponent(id));
        }

        var CONFIG = {
            fav: {
                cls:     'is-active-heart',
                action:  'ToggleFavorite',
                onMsg:   '❤️ Added to Favorites',
                offMsg:  '💔 Removed from Favorites',
                onTip:   'Remove Favorite',
                offTip:  'Add Favorite'
            },
            watch: {
                cls:     'is-active-clock',
                action:  'ToggleWatchList',
                onMsg:   '🕐 Added to Watchlist',
                offMsg:  '✖️ Removed from Watchlist',
                onTip:   'Remove from Watchlist',
                offTip:  'Watch Later'
            }
        };

        window.toggleBtn = function (btn) {
            var id   = btn.getAttribute('data-movie-id');
            var type = btn.getAttribute('data-type');
            var cfg  = CONFIG[type];

            if (!cfg || !validId(id)) {
                toast('⚠️ Invalid movie');
                return;
            }

            var wasActive = btn.classList.contains(cfg.cls);
            var next      = !wasActive;
            var tip       = btn.querySelector('.icon-tooltip');

            // Optimistic UI
            if (next) {
                btn.classList.add(cfg.cls);
            } else {
                btn.classList.remove(cfg.cls);
            }
            tip.textContent = next ? cfg.onTip : cfg.offTip;
            localSet(type, id, next);

            // Re-trigger animation
            var fullIcon = btn.querySelector('.icon-full');
            if (next && fullIcon) {
                fullIcon.style.animation = 'none';
                fullIcon.offsetHeight; // reflow
                fullIcon.style.animation = '';
            }

            ajax(cfg.action, id, function (ok) {
                if (!ok) {
                    // Revert
                    if (wasActive) btn.classList.add(cfg.cls);
                    else           btn.classList.remove(cfg.cls);
                    tip.textContent = wasActive ? cfg.onTip : cfg.offTip;
                    localSet(type, id, wasActive);
                    toast('❌ Something went wrong');
                } else {
                    toast(next ? cfg.onMsg : cfg.offMsg);
                }
            });
        };

    })();
</script>
<script>

    function addReview(movieId)
    {
        let comment =
            document.getElementById("reviewComment").value;

        if(comment.trim() === "")
        {
            toast("Write a review first");
            return;
        }

        $.ajax({
            url: '/Review/Create',
            type: 'POST',
            data: {
                movieId: movieId,
                comment: comment
            },
            success: function(res)
            {
                let html = `
                    <div class="card bg-black border-secondary mb-3 review-item">
                        <div class="card-body">
                            <h6 class="text-warning">
                                ${res.user}
                            </h6>

                            <p class="text-light mb-0">
                                ${res.comment}
                            </p>
                        </div>
                    </div>
                `;

                $("#reviewsContainer").prepend(html);

                $("#reviewComment").val("");

                toast("Review Added Successfully");
            },
            error: function()
            {
                toast("Failed To Add Review");
            }
        });
    }

</script>